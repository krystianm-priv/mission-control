{
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"types": ["node"],
		"target": "esnext",
		"module": "nodenext",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	},
	"exclude": ["**/*.test.ts"]
}
