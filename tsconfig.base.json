{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"noUncheckedIndexedAccess": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"exactOptionalPropertyTypes": true,
		"types": ["node"]
	}
}
