{
	"name": "@mission-control/in-memory-commander",
	"version": "1.0.0-rc.1",
	"description": "In-memory commander implementation for Mission Control.",
	"type": "module",
	"license": "MIT",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"README.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"lint": "biome check .",
		"test": "sh -c 'node --test $(find dist -name \"*.test.js\" -print)'"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@mission-control/core": "workspace:*"
	}
}
