{
	"name": "@mission-control/postgres-commander",
	"version": "1.0.0-rc.1",
	"description": "Postgres-backed durable commander for Mission Control.",
	"type": "module",
	"license": "MIT",
	"engines": {
		"node": "^24"
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"src",
		"!src/**/*.test.ts",
		"README.md"
	],
	"scripts": {
		"check-types": "tsc -p tsconfig.json --noEmit",
		"lint": "biome check .",
		"test": "sh -c 'node --experimental-strip-types --test $(find src -name \"*.test.ts\" -print)'"
	},
	"dependencies": {
		"@mission-control/core": "*"
	}
}
