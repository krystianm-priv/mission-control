{
	"name": "mission-control",
	"type": "module",
	"private": true,
	"packageManager": "npm@11.11.0",
	"engines": {
		"node": ">=24"
	},
	"engineStrict": true,
	"scripts": {
		"format": "biome check --write --unsafe",
		"lint": "biome check .",
		"build": "npm run build --workspaces --if-present",
		"check-types": "tsc",
		"test": "node --test",
		"test:watch": "node --test --watch",
		"release:check": "npm run check-types && npm run lint && npm run test && npm run release:pack",
		"release:pack": "npm run build && npm_config_cache=/tmp/mission-control-npm-cache npm pack ./core/dist ./adapters/in-memory/dist ./adapters/sqlite/dist ./runtime/dist ./client/dist ./testing/dist --dry-run"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@types/node": "^24",
		"typescript": "6.0.2"
	},
	"workspaces": [
		"core",
		"runtime",
		"client",
		"testing",
		"adapters/*",
		"examples/*"
	]
}
